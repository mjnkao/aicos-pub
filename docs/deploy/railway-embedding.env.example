# Railway embedding variables for aicos-pub.
# Copy this file to:
#   .runtime-home/railway-embedding.env
# Then fill OPENAI_API_KEY locally. Do not commit the filled file.

OPENAI_API_KEY=<paste-openai-api-key-here>
AICOS_EMBEDDINGS=auto
AICOS_EMBEDDING_MODEL=text-embedding-3-small
AICOS_EMBEDDING_DIMENSIONS=1536
AICOS_EMBEDDING_BATCH_SIZE=32
